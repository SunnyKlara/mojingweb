NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017/mojing
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-32-plus-char-random-string-0123456789
JWT_REFRESH_SECRET=replace-me-with-another-32-plus-char-random-string-abcdef
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@example.com

# Optional — leave blank to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
NOTIFY_EMAIL=

SENTRY_DSN=
LOG_LEVEL=info
