{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter=frontend build",
  "installCommand": "pnpm install --frozen-lockfile",
  "outputDirectory": "frontend/.next",
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- frontend shared pnpm-lock.yaml package.json"
}
