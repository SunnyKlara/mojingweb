engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
save-exact=false
# Non-interactive installs — required for CI and for Cascade-driven runs.
# When .npmrc / hoist patterns change, pnpm would otherwise prompt
# "modules directory will be removed ... Proceed? (Y/n)". Auto-accept.
confirm-modules-purge=false

# Hoist transitive deps needed by lint-staged (yaml, micromatch) and by
# Next/React toolchain typing (needed for type discovery in pnpm isolated mode).
# Without this, `lint-staged` fails to load `yaml` and commits require
# `--no-verify`. See ADR in docs/DECISIONS.md (T1 rationale).
public-hoist-pattern[]=*yaml*
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@types/*
# Sentry + OpenTelemetry use plugin-style transitive resolution (e.g.
# `require('./impl')` within @opentelemetry/api). Needs hoisting or pnpm
# isolated mode leaves the sub-paths invisible.
public-hoist-pattern[]=@opentelemetry/*
public-hoist-pattern[]=@sentry/*
