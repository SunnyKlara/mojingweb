# Backend (Express + Socket.io) — optional, not deployed yet.
# Leave unset in production until the backend is live.
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Web3Forms access key for the contact form (https://web3forms.com/).
# A fallback key is hard-coded in the component, but set this to override per-environment.
NEXT_PUBLIC_WEB3FORMS_KEY=

# --- Sentry (observability) — optional in local dev, required in production. ---
# DSN is the per-project URL from https://sentry.io/settings/<org>/projects/<project>/keys/
NEXT_PUBLIC_SENTRY_DSN=
# Override environment name (defaults to NODE_ENV). Useful for staging/preview.
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Set to a git sha or semver to group errors by release; injected by CI.
NEXT_PUBLIC_SENTRY_RELEASE=
# Server-side variants (read in sentry.server.config.ts + next.config.mjs).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Required ONLY for CI to upload source maps. Create at
# https://sentry.io/settings/account/api/auth-tokens/ with `project:releases` scope.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=modelzone-frontend
