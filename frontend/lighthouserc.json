{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter=frontend start -p 3000",
      "startServerReadyPattern": "ready|Listening on",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/zh",
        "http://localhost:3000/zh/blog",
        "http://localhost:3000/zh/cases"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop",
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "comment": "Week 1 policy (ADR-0005): baseline-only. No assertions fail CI. Hard budgets enforced from Week 6 with real data.",
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": "off",
        "categories:accessibility": "off",
        "categories:best-practices": "off",
        "categories:seo": "off"
      }
    }
  }
}
