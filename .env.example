# =============================================================================
# Root .env.example — catalog of every variable used anywhere in the project.
# Canonical per-package files live at `frontend/.env.local.example` and
# `backend/.env.example`. Copy those, not this one, when setting up locally.
# =============================================================================

# ---------- Backend (backend/.env) ----------
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# MongoDB Atlas connection string (use mongodb+srv://... in production).
MONGODB_URI=mongodb://localhost:27017/modelzone

# JWT — generate each with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-another-openssl-rand-hex-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Admin seed (first boot creates this user; rotate password on first login).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@example.com

# SMTP (lead / chat notifications). Leave blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ModelZone <no-reply@example.com>"
NOTIFY_EMAIL=

# Sentry (backend).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# Logging
LOG_LEVEL=info

# ---------- Frontend (frontend/.env.local) ----------
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact form — Web3Forms fallback key (see ADR-0009 in docs/DECISIONS.md).
NEXT_PUBLIC_WEB3FORMS_KEY=

# Sentry (frontend — public DSN is safe to ship to browser).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_RELEASE=
# Server-side variants (read by next.config.mjs + sentry.server.config.ts).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
# Source map upload — only set in CI.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=modelzone-frontend

# ---------- Not used in V1 (scaffolded for V2 / V5) ----------
# Resend (email provider for V2 pre-order notifications).
# RESEND_API_KEY=
# AI assistant (LLM provider chosen at end of Week 4 — see ADR-0004).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Stripe (V2 pre-order checkout).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
