# =============================================================================
# Root .env.example — copy to each package's .env and customize.
# Canonical per-package files live at frontend/.env.local.example and
# backend/.env.example. This file documents every variable used anywhere.
# =============================================================================

# ---------- Backend ----------
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mojing

# Redis (Socket.io adapter + Bull queue + cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-another-openssl-rand-hex-32
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Admin seed (first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password
ADMIN_EMAIL=admin@example.com

# SMTP (email notifications) — or use Resend below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app_password
SMTP_FROM="GlobalBridge <no-reply@example.com>"
NOTIFY_EMAIL=sales@example.com

# Resend (preferred, set either SMTP_* or RESEND_API_KEY)
RESEND_API_KEY=

# Sentry
SENTRY_DSN=

# ---------- Frontend ----------
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
